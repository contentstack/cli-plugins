{
  "name": "contentstack-cli-tsgen",
  "description": "Generate TypeScript typings from a Stack.",
  "version": "4.10.0",
  "author": "Contentstack",
  "bugs": "https://github.com/contentstack/cli-plugins/issues",
  "dependencies": {
    "@contentstack/cli-command": "~1.8.3",
    "@contentstack/cli-utilities": "~1.18.4",
    "@contentstack/types-generator": "^3.10.1"
  },
  "devDependencies": {
    "@oclif/plugin-help": "^6.2.49",
    "@oclif/test": "^4.1.18",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-oclif": "^6.0.165",
    "eslint-config-oclif-typescript": "^3.1.14",
    "jest": "^29.7.0",
    "oclif": "^4.23.8",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "/lib",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/contentstack/cli-plugins/tree/v1-dev/packages/contentstack-cli-tsgen",
  "keywords": [
    "contentstack",
    "cli",
    "plugin",
    "typescript"
  ],
  "license": "MIT",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "csdx",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "repositoryPrefix": "<%- repo %>/blob/main/packages/contentstack-cli-tsgen/<%- commandPath %>"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contentstack/cli-plugins.git",
    "directory": "packages/contentstack-cli-tsgen"
  },
  "scripts": {
    "build": "pnpm compile && oclif manifest && oclif readme",
    "clean": "rm -rf ./lib ./node_modules tsconfig.tsbuildinfo",
    "compile": "tsc -b tsconfig.json",
    "lint": "eslint . --ext .ts --config .eslintrc.js",
    "postpack": "rm -f oclif.manifest.json",
    "posttest": "eslint . --ext .ts --config .eslintrc.js --fix",
    "prepack": "pnpm compile && oclif manifest && oclif readme",
    "test": "jest --testPathPattern=tests",
    "test:integration": "jest --testPathPattern=tests/integration",
    "version": "oclif readme && git add README.md"
  },
  "csdxConfig": {
    "shortCommandName": {
      "tsgen": "TSGEN"
    }
  }
}
