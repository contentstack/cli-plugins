{
  "extension": [
    ".ts"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "**/*.d.ts",
    "test/**",
    "lib/**"
  ],
  "reporter": [
    "text",
    "lcov",
    "html",
    "json",
    "json-summary",
    "clover"
  ],
  "all": true,
  "check-coverage": true,
  "lines": 80,
  "statements": 80,
  "functions": 80,
  "branches": 75
}

