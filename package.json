{
  "name": "csdx",
  "version": "1.0.0",
  "devDependencies": {
    "husky": "^9.1.7",
    "pnpm": "^10.28.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "clean": "pnpm -r --filter './packages/*' run clean",
    "build": "pnpm -r --filter './packages/*' run build",
    "test": "pnpm -r --filter './packages/*' run test",
    "prepack": "pnpm -r --filter './packages/*' run prepack",
    "bootstrap": "pnpm install",
    "clean:modules": "rm -rf node_modules packages/**/node_modules",
    "clean:lock": "rm -f pnpm-lock.yaml",
    "clean:all": "pnpm store prune && pnpm run clean:modules && pnpm run clean:lock",
    "setup": "pnpm run clean:all && pnpm run boootstrap && pnpm run build",
    "prepare": "npx husky && chmod +x .husky/pre-commit",
    "prepare-publish": "node scripts/prepare-publish.js",
    "publish:packages": "pnpm prepare-publish && pnpm publish -r --access public",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release:beta:enter": "changeset pre enter beta",
    "release:beta:exit": "changeset pre exit",
    "release:beta:version": "changeset version && pnpm install",
    "release:beta:publish": "pnpm build && changeset publish --tag beta",
    "release:beta": "pnpm release:beta:version && pnpm release:beta:publish",
    "release:stable:version": "changeset version && pnpm install",
    "release:stable:publish": "pnpm build && changeset publish",
    "release:stable": "pnpm release:stable:version && pnpm release:stable:publish",
    "release:version": "changeset version && pnpm install",
    "release:publish": "pnpm build && changeset publish",
    "sync:versions": "node scripts/sync-versions.js"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ]
}
